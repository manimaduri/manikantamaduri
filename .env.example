# ---------------------------------------------------------------------------
# Portfolio environment variables
# Copy to .env.local for development; set the same in Vercel for production.
# Everything is OPTIONAL for local dev — the contact pipeline degrades
# gracefully when a service isn't configured.
# ---------------------------------------------------------------------------

# Canonical site URL (no trailing slash). Used for SEO, sitemap, OG images.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# --- Contact form: email delivery (Resend) ---------------------------------
# https://resend.com — free tier 3,000/mo, 100/day
RESEND_API_KEY=
# Sender must be on a Resend-verified domain in production.
# For testing you can use: Portfolio <onboarding@resend.dev>
CONTACT_FROM_EMAIL=Portfolio <onboarding@resend.dev>
# Where submissions are delivered (defaults to profile.email)
CONTACT_TO_EMAIL=manikantamaduri2023@gmail.com

# --- Contact form: bot protection (Cloudflare Turnstile) -------------------
# https://dash.cloudflare.com/?to=/:account/turnstile — free, unlimited
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Contact form: rate limiting (Upstash Redis) ---------------------------
# https://upstash.com — free tier
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Contact form: Google Sheets log (Apps Script web-app webhook) ---------
# Deploy an Apps Script that appendRow()s e.postData.contents, paste /exec URL.
GOOGLE_SHEETS_WEBHOOK_URL=

# --- SEO: Google Search Console verification -------------------------------
GOOGLE_SITE_VERIFICATION=
